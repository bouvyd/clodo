# Local machine configuration
/.devcontainer/.env

# Mounted source repos live here at runtime; keep only the mountpoints.
/src/*
!/src/.gitkeep

# Odoo filestore / sessions (bind-mounted at runtime)
/.odoo/

# Local Odoo config (machine-specific, not committed — see odoo.conf.example)
/odoo.conf

# Timestamped script log files
/logs/

# Vendored from $ODOO_SRC at setup time (regenerated by bin/sync-requirements.sh)
/.devcontainer/requirements.odoo.txt
