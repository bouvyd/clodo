# Active configuration for THIS machine. Not committed (see .gitignore).
COMPOSE_PROJECT_NAME=clodo-19
ODOO_VERSION=19.0
PYTHON_BASE=python:3.12-bookworm

# Match the container user to your host user so rw mounts stay your-owned.
USER_UID=1000
USER_GID=1000

# The clodo workspace (this repo). Relative to .devcontainer/ where compose runs.
WORKSPACE=..

# Host paths to the already-cloned source repositories.
ODOO_SRC=/path
ENTERPRISE_SRC=/path
DESIGN_THEMES_SRC=/path
CUSTOM_ADDONS=/path

# Database
DB_USER=odoo
DB_PASSWORD=odoo

# Host port mappings (bump these to run several versions side by side).
ODOO_HTTP_PORT=8069
ODOO_GEVENT_PORT=8072
DB_PORT=5433
